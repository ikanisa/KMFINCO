# Public contact details
NEXT_PUBLIC_CONTACT_EMAIL=hello@kmfinco.com

# Replace with the final Google Calendar Appointment Schedule URL.
# Without it, the website opens a pre-addressed Google Calendar event.
NEXT_PUBLIC_GOOGLE_BOOKING_URL=

# Verified KM FINCO company profile only. Leave blank until confirmed.
NEXT_PUBLIC_LINKEDIN_URL=

# Native Google Calendar API booking. The Google account must grant offline
# Calendar access and the selected calendar must permit event creation.
GOOGLE_CALENDAR_CLIENT_ID=
GOOGLE_CALENDAR_CLIENT_SECRET=
GOOGLE_CALENDAR_REFRESH_TOKEN=
GOOGLE_CALENDAR_ID=primary
GOOGLE_CALENDAR_TIMEZONE=Europe/Malta

# Google Analytics 4 measurement ID, for example G-XXXXXXXXXX.
# Analytics stays off when blank and loads only after visitor consent.
NEXT_PUBLIC_GA_MEASUREMENT_ID=

# Google Search Console HTML-tag verification token.
GOOGLE_SITE_VERIFICATION=
